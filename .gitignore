# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# --- tooling / env ---
.pixi/
.env

# --- agy/antigravity runtime capture output (see test_scripts/run-agy.sh AGY_PROC_CAPTURE) ---
*.jsonl
captures/

# --- antigravity build deps + artifacts (all under antigravity/, never committed) ---
# Vendored/fetched deps + the built shim — recreate with `pixi run build-shim`:
#   vendor/agy (~164 MB binary), vendor/frida-gum (devkit),
#   vendor/antigravity.so (compiled LD_PRELOAD shim).  UAPI headers are NOT vendored
#   (referenced in place from the kernel-headers_linux-64 conda dep — see CMakeLists.txt).
antigravity/vendor/
# cmake build tree + the compile db it symlinks to the source root (for clangd):
antigravity/build/
antigravity/compile_commands.json
# generated from symbols.json at build time:
antigravity/src/symbols_gen.h
antigravity/symbols/goresym.json
# full addr→name table for stack symbolization (regenerated by `pixi run shim-symbols`):
antigravity/symbols/funcmap.tsv.gz

# --- Node (pymport bridge) ---
node_modules/
package-lock.json
