/* proc.def — declarative hook table (X-macro).
 *
 *   HOOK(ID, "go.symbol.Name", MODE, "kind", STAGE, LEAVE)
 *
 * ID     enum tag used in the on_enter/on_leave switch (register semantics are
 *        coded per-ID in antigravity.c — different funcs read different registers).
 * MODE   AGY_ASYNC (log, non-blocking) or AGY_SYNC (block for a modify verdict).
 * kind   string tag passed to Python dispatch(kind, stream_id, data).
 * STAGE  which AGY_PROC_STAGE this hook belongs to (incremental WSL1 bring-up):
 *          stage 1 = python only; stage 2 = ONLY stage-2 hooks (smoke);
 *          stage >=3 = ONLY stage->=3 hooks (the real ones).
 * LEAVE  1 => needs on_leave (return-value interception). Costs a return-address
 *        rewrite that Go's stack unwinder can trip on, so keep it to hooks that
 *        truly need the return value. NEVER hook runtime-special funcs
 *        (runtime.main, goroutine entries) — Go validates their return PC.
 */

/* STAGE now selects EXACTLY that stage's hooks (2=smoke, 3=tls/http, 4=serializers).
 * Safe ordinary startup function; fires many times, no auth/network needed. */
HOOK(SMOKE_GETENV, "os.Getenv",                      AGY_ASYNC, "smoke",     2, 0)

/* stage 3: egress capture. tls_write is safe once we attach PAST the prologue
 * (per-hook skip from symbols.json) — it doesn't park, so no morestack re-entry
 * and no park-while-hooked hazard. Captures the full model REQUEST. */
HOOK(TLS_WRITE,    "crypto/tls.(*Conn).Write",        AGY_ASYNC, "tls_write", 3, 0)
/* http2 pipe.Write gets each de-framed response body chunk as []byte
 * (RBX=ptr,RCX=len) — BUT it takes a sync.Mutex/cond and PARKS under
 * reader/writer contention, so hooking it stalls agy (stage 5, reference only,
 * same park hazard as tls_read). Use TLS_DECRYPT for the response instead. */
HOOK(H2_PIPE_WRITE,"net/http/internal/http2.(*pipe).Write", AGY_ASYNC, "resp",   5, 0)
/* ingress RESPONSE via TLS decrypt (CPU-only, post-read → doesn't park). on_leave
 * []byte = decrypted inbound record (HTTP/2 frames of the response). */
HOOK(TLS_DECRYPT,  "crypto/tls.(*halfConn).decrypt",   AGY_ASYNC, "tls_read",  3, 1)
/* stage 5: these STALL agy — tls_read/RoundTrip PARK the goroutine while hooked
 * (even on-enter-only, past-prologue). Kept for reference; response capture must
 * use a non-parking CPU func (codecV2.Unmarshal) or the PTY transcript. */
HOOK(TLS_READ,     "crypto/tls.(*Conn).Read",         AGY_ASYNC, "tls_read",  5, 1)
HOOK(HTTP_RT,      "net/http.(*Transport).RoundTrip", AGY_ASYNC, "http_rt",   5, 0)

/* stage 4: app-layer capture R&D — CPU-only funcs returning []byte (readable). */
HOOK(SER_ROOT,     "google3/third_party/jetski/cli/model/model.(*RootModel).Serialize",    AGY_ASYNC, "serialize", 4, 1)
HOOK(MAR_PROMPT,   "google3/third_party/jetski/cli/model/model.(*PromptModel).MarshalJSON", AGY_ASYNC, "marshal",   4, 1)
HOOK(PROTO_MARSHAL,"google3/third_party/golang/gogo/protobuf/proto/proto.Marshal",            AGY_ASYNC, "proto_marshal", 4, 1)

/* RATIONALE (former stages 6-7, removed once the trampoline below proved out): a naive
 * gum attach on the parking funcs `SendUserMessage`/`callbackStreamer.Send` (stage 6) and
 * a cgo-gateway probe on `runtime.cgocall` (stage 7) were experiments. Both parking funcs
 * FIRE in-process, but a gum attach makes agy's turn produce NO answer — they're on the
 * goroutine-scheduling path, so gum's per-thread return-tracking corrupts the turn (same
 * hazard as stage 5). Stage 8 hooks the SAME targets via the cgocall trampoline instead,
 * which never intercepts the return and so is park-safe. */

/* stage 8: cgocall-TRAMPOLINE hooks (Approach A — the robust general mechanism).
 * The parking targets (SendUserMessage/callbackStreamer.Send), but instead of a gum
 * attach (whose return-tracking breaks on park/reschedule) we redirect them through runtime.cgocall via
 * a generated trampoline (gohook.c) + a synthetic moduledata (set AGY_PROC_MODULEDATA=1)
 * so GC stack-unwind is safe. MODE/leave are advisory here — the trampoline path
 * reads args on the g0 stack and never intercepts the return. */
HOOK(CGT_SEND_USER_MSG, "google3/third_party/jetski/cli/backend/backend.(*ServerBackend).SendUserMessage", AGY_ASYNC, "send_user_msg", 8, 0)
HOOK(CGT_STREAM_SEND,   "google3/third_party/jetski/cli/backend/backend.(*callbackStreamer).Send",          AGY_ASYNC, "stream_send",   8, 0)

/* stage 9: cgocall-trampoline TOOL validation on a BENIGN function. os.Getenv is
 * CPU-only, non-parking, not on agy's request/response concurrency path — if the
 * trampoline works here (agy answers + hook fires many times) the tool is sound
 * and SendUserMessage/Send (stage 8) are simply intolerant of a syscall transition
 * at entry. Uses the same gohook.c path as stage 8. */
HOOK(CGT_GETENV, "os.Getenv", AGY_ASYNC, "cgt_getenv", 9, 0)
